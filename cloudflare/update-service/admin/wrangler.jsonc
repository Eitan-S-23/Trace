{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "trace-update-admin-staging",
  "pages_build_output_dir": "./public",
  "compatibility_date": "2026-06-28",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "ENVIRONMENT": "staging",
    "APP_ID": "trace",
    "ACCESS_JWT_ISSUER": "",
    "ACCESS_JWT_AUD": "",
    "ADMIN_VIEWER_EMAILS": "",
    "ADMIN_PUBLISHER_EMAILS": "",
    "ADMIN_OWNER_EMAILS": "",
    "ADMIN_ALLOWED_ORIGINS": ""
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "trace-update-staging",
      "database_id": "0133ad9e-d4a2-4fef-a659-4f2bf3d3a645",
      "migrations_dir": "../migrations"
    }
  ]
}
